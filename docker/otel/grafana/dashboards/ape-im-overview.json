          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_VICTORIAMETRICS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(rpc_server_duration_ms_bucket{service_name=\"ape-server\"}[5m])) by (le, rpc_service))",
          "legendFormat": "P95 - {{rpc_service}}",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_VICTORIAMETRICS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(rpc_server_duration_ms_bucket{service_name=\"ape-server\"}[5m])) by (le, rpc_service))",
          "legendFormat": "P99 - {{rpc_service}}",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "gRPC 延迟分布 (P50 / P95 / P99)",
      "description": "Histogram: histogram_quantile 从 rpc_server_duration_ms 的 bucket 数据中计算分位数。P50=中位数, P95=95%请求, P99=99%请求。注意 P95 和 P99 之间的差距——差距越大说明长尾问题越严重。",
      "type": "timeseries"
    }
